<style xml:id="style7" tts:fontSize="100.000%" tts:ruby="container" tts:shear="16.670%"/>
<style xml:id="style8" tts:fontSize="100.000%" tts:ruby="base" tts:shear="16.670%"/>
<style xml:id="style9" tts:ruby="text" tts:rubyAlign="center" tts:rubyPosition="outside" tts:shear="16.670%"/>
